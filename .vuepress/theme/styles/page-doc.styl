@require './palette.styl'

// 文档/文章阅读页：主内容玻璃面板；正文列用 min(72ch, $readingColumnMax) 居中，符合行长阅读习惯，缓解三栏拥挤

.page-doc
  max-width none
  width 100%
  margin 0
  padding 0 0.75rem
  box-sizing border-box

// 白底卡片与正文同一阅读宽度，整体居中（不再出现「外宽内窄」）
.page-doc__card
  max-width unquote('min(200ch, ' + $readingColumnMax + ')')
  width 100%
  margin-left auto
  margin-right auto
  box-sizing border-box
  background rgba(255, 255, 255, 0.72)
  backdrop-filter blur(16px) saturate(165%)
  border 1px solid rgba(255, 255, 255, 0.5)
  border-radius 18px
  box-shadow 0 12px 48px rgba(15, 23, 42, 0.09), 0 2px 12px rgba(15, 23, 42, 0.04)
  overflow hidden

.page-doc__card--compact
  padding 1rem 1.5rem
  margin-top 1rem

.page .page-doc .page-title
  max-width 100%
  margin 0
  padding 1.35rem 1.75rem 1.1rem
  border-bottom 1px solid rgba(15, 23, 42, 0.07)
  background linear-gradient(180deg, rgba(255, 255, 255, 0.45) 0%, rgba(248, 250, 252, 0.15) 100%)
  box-sizing border-box

.page .page-doc .page-title .title
  font-size 1.85rem
  font-weight 700
  letter-spacing -0.02em
  line-height 1.3
  margin 0 0 0.5rem

.page .page-doc .theme-reco-content
  padding 1.5rem 1.75rem 2.5rem

// 宽度由外层 .page-doc__card 约束，内层铺满卡片
.page .page-doc .theme-reco-content.content__default
  max-width 100% !important
  width 100%
  margin-left 0 !important
  margin-right 0 !important
  box-sizing border-box

.page .page-doc--footer
  margin-top 0.5rem

// 底部「最后更新」、上下篇、评论：不再使用与白底卡片，与页面背景一致
.page-doc--footer .page-doc__card--compact,
.page-doc--nav .page-doc__card--compact
  background transparent !important
  backdrop-filter none
  border none
  box-shadow none
  border-radius 0

.page-doc--footer .page-doc__card--compact
  border-top none
  padding-top 0.85rem

// 上下篇仍用 .page-nav .inner 顶部分隔线，避免与 card 顶边重复
.page-doc--nav .page-doc__card--compact
  padding-top 0

.dark .page-doc--footer .page-doc__card--compact
  background transparent !important

.dark .page-doc--nav .page-doc__card--compact
  background transparent !important

.page .page-doc--nav
  margin-top 0.75rem

.page .page-doc .page-nav
  margin 0
  padding 0

.page .page-doc .page-nav .inner
  margin-top 0
  padding-top 0.85rem
  border-top 1px solid rgba(15, 23, 42, 0.08)

.page .page-doc .page-edit
  padding 0
  overflow visible

.dark .page-doc__card
  background rgba(30, 41, 59, 0.72)
  border-color rgba(255, 255, 255, 0.1)
  box-shadow 0 16px 56px rgba(0, 0, 0, 0.35)

.dark .page .page-doc .page-title
  border-bottom-color rgba(255, 255, 255, 0.1)
  background linear-gradient(180deg, rgba(30, 41, 59, 0.6) 0%, rgba(15, 23, 42, 0.2) 100%)

.dark .page .page-doc .page-nav .inner
  border-top-color rgba(255, 255, 255, 0.1)

@media (max-width: $MQMobile)
  .page-doc
    padding 0 0.85rem
  .page-doc__card
    max-width 100%
  .page .page-doc .page-title
    padding 1rem 1.1rem 0.85rem
  .page .page-doc .theme-reco-content
    padding 1.1rem 1.1rem 1.75rem
