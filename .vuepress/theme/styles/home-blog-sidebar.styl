.home-blog {
  padding: 0;
  margin: 0px auto;
  position relative;
  z-index 1;
  .home-blog-wrapper {
    display flex
    align-items: flex-start;
    margin 20px auto 0
    padding 0 20px
    max-width $homePageWidth
    .blog-list {
      flex auto
      width 0
      .abstract-wrapper {
        .abstract-item:last-child {
          margin-bottom: 0px;
        }
      }
    }
    .info-wrapper {
      position -webkit-sticky
      position sticky
      top 70px
      overflow visible
      transition box-shadow 0.25s ease, border-color 0.25s ease
      margin-left 15px
      flex 0 0 300px
      height auto
      box-sizing border-box
      padding 0
      border-radius 16px
      border 1px solid rgba(255, 255, 255, 0.55)
      background rgba(255, 255, 255, 0.9)
      backdrop-filter blur(14px) saturate(160%)
      box-shadow 0 8px 36px rgba(15, 23, 42, 0.12), 0 2px 8px rgba(15, 23, 42, 0.06)
      &:hover {
        box-shadow 0 14px 48px rgba(15, 23, 42, 0.14)
        border-color rgba(255, 255, 255, 0.75)
      }
    }

    .info-block {
      padding 1rem 1.15rem
      border-bottom 1px solid rgba(15, 23, 42, 0.07)
      &:last-child {
        border-bottom none
      }
    }

    .info-block--profile {
      padding-top 1.1rem
      padding-bottom 0.85rem
      >>> .personal-info-wrapper hr {
        display none
      }
    }

    .info-heading {
      margin 0 0 0.85rem
      font-size 0.6875rem
      font-weight 600
      letter-spacing 0.07em
      text-transform uppercase
      color var(--text-color-sub)
      display flex
      align-items center
      gap 0.45rem
      line-height 1.3
      .iconfont {
        font-size 1rem
        opacity 0.88
      }
    }

    .info-wrapper .category-wrapper {
      list-style none
      margin 0
      padding 0
      .category-item {
        margin-bottom 0.35rem
        padding 0
        border-radius 0
        box-shadow none
        background transparent
        &:last-child {
          margin-bottom 0
        }
        &:hover {
          transform none
        }
        a {
          display flex
          justify-content space-between
          align-items center
          gap 0.5rem
          padding 0.5rem 0.65rem
          border-radius 12px
          color var(--text-color)
          text-decoration none
          border 1px solid transparent
          transition border-color 0.2s ease, background 0.2s ease, color 0.2s ease
          &:hover {
            color $accentColor
            background rgba(13, 148, 136, 0.07)
            border-color rgba(13, 148, 136, 0.22)
          }
        }
        .category-name {
          flex 1
          min-width 0
          font-size 0.875rem
          font-weight 500
          line-height 1.35
          overflow hidden
          text-overflow ellipsis
          white-space nowrap
        }
        .post-num {
          flex-shrink 0
          min-width 1.5rem
          height 1.5rem
          padding 0 0.35rem
          text-align center
          line-height 1.5rem
          border-radius 999px
          font-size 0.7rem
          font-weight 600
          color var(--text-color-sub)
          background rgba(15, 23, 42, 0.08)
        }
        a:hover .post-num {
          background rgba(13, 148, 136, 0.15)
          color $accentColor
        }
      }
    }

    .info-wrapper >>> .tags {
      margin 0
      gap 0.4rem 0.45rem
    }
    .info-wrapper >>> .tags span.tag-item {
      margin 0
      padding 0.28rem 0.6rem
      font-size 0.72rem
      line-height 1.35
      border-radius 999px
      box-shadow none
      vertical-align middle
    }
    .info-wrapper >>> .friend-link-wrapper {
      margin 0
    }
    .info-wrapper >>> .friend-link-item {
      margin 3px 4px 8px
      padding 0.35rem 0.65rem 0.35rem 1.1rem
      border-radius 999px
      box-shadow none
      border 1px solid rgba(15, 23, 42, 0.08)
      background rgba(255, 255, 255, 0.65)
      transition background 0.2s ease, border-color 0.2s ease
      &:hover {
        background rgba(13, 148, 136, 0.08)
        border-color rgba(13, 148, 136, 0.25)
      }
    }
  }
}

.dark .home-blog .info-wrapper .category-wrapper
  .post-num
    background rgba(255, 255, 255, 0.08)
    color var(--text-color-sub)
  a:hover .post-num
    background rgba(13, 148, 136, 0.15)
    color lighten($accentColor, 12%)

@media (max-width: $MQMobile) {
  .home-blog {
    .home-blog-wrapper {
      display block!important
      .blog-list {
        width auto
      }
      .info-wrapper {
        margin-left 0
        .personal-info-wrapper {
          display none
        }
      }
    }
  }
}

@media (max-width: $MQMobileNarrow) {
  .home-blog {
    .home-blog-wrapper {
      display block!important
      .blog-list {
        width auto
      }
      .info-wrapper {
        margin-left 0
        .personal-info-wrapper {
          display none
        }
      }
    }
  }
}
