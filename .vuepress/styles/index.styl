// 首页整页背景由 Layout 中 .home-page-shell 的 bgImage 铺满，不再铺灰底
body
  background linear-gradient(180deg, #f1f5f9 0%, #f8fafc 32%, #ffffff 100%)
  min-height 100vh

// 首页：背景图覆盖 Hero + 列表 + 侧栏 + 页脚整块区域
// 原 hero-overlay 渐变：整壳铺满（盖在 bgImage 之上、内容之下）
.home-page-shell
  position relative
  width 100%
  min-width 0
  min-height calc(100vh - 3.6rem)
  box-sizing border-box
  isolation isolate
  &::before
    content ''
    position absolute
    inset 0
    z-index 0
    pointer-events none
    background linear-gradient(135deg, rgba(15, 23, 42, 0.78) 0%, rgba(15, 118, 110, 0.45) 55%, rgba(15, 23, 42, 0.65) 100%)

.home-page-shell .footer
  position relative
  z-index 1
  background rgba(255, 255, 255, 0.88)
  backdrop-filter saturate(160%) blur(12px)
  border-top 1px solid rgba(15, 23, 42, 0.08)

.dark .home-page-shell .footer
  background rgba(24, 24, 24, 0.88)
  border-top-color rgba(255, 255, 255, 0.1)

.dark .home-page-shell .home-blog .info-wrapper
  background rgba(30, 41, 59, 0.85)
  border-color rgba(255, 255, 255, 0.12)
  box-shadow 0 12px 40px rgba(0, 0, 0, 0.35)
  .info-block
    border-bottom-color rgba(255, 255, 255, 0.08)
  .friend-link-wrapper .friend-link-item
    background rgba(15, 23, 42, 0.5)
    border-color rgba(255, 255, 255, 0.1)

// 首页博文列表分页：插件默认整块 var(--background-color) 白底，改为透明并收紧行高
.home-page-shell .abstract-wrapper .pagation
  background transparent !important
  margin 1rem auto 0
  padding 0
  color rgba(248, 250, 252, 0.88)
  .pagation-list
    line-height 2.25
    padding 0.35rem 0
  .pagation-list .ellipsis
    color rgba(248, 250, 252, 0.55)
  .pagation-list .jumppoint
    color rgba(248, 250, 252, 0.65)
  .pagation-list .jump
    background rgba(255, 255, 255, 0.9)
    backdrop-filter blur(8px) saturate(150%)
    border-color rgba(15, 23, 42, 0.12) !important
    color var(--text-color)
    box-shadow 0 2px 10px rgba(15, 23, 42, 0.1)
    &:hover
      background rgba(255, 255, 255, 0.98)
      border-color rgba(15, 23, 42, 0.18) !important
  .pagation-list .jump.bgprimary
    background $accentColor !important
    color #fff !important
    border-color $accentColor !important
    box-shadow 0 4px 14px rgba(13, 148, 136, 0.35)
    &:hover
      background $accentColor !important
      color #fff !important
  .pagation-list .jumpinp input
    background rgba(255, 255, 255, 0.9) !important
    backdrop-filter blur(8px)
    border-color rgba(15, 23, 42, 0.14) !important
    color var(--text-color)
    box-shadow 0 2px 10px rgba(15, 23, 42, 0.1)

.dark body
  background #0f172a
  min-height 100vh

.dark .content__default code
  background-color rgba(58, 58, 92, 0.8)
  color #fff

// 顶栏：不铺白底，仅保留轻微底边与毛玻璃，随页面背景透出
.navbar
  border-bottom 1px solid rgba(15, 23, 42, 0.08)
  background transparent !important
  backdrop-filter saturate(160%) blur(10px)
  box-shadow none !important

.dark .navbar
  background transparent !important
  border-bottom 1px solid rgba(255, 255, 255, 0.1)

// 左侧文档侧栏
.sidebar > .sidebar-links > li > a.sidebar-link
  font-size 1.5em !important
  margin-left -1em

// 仅左侧目录，避免影响右侧大纲 .sub-sidebar-link
.sidebar a.sidebar-link
  font-size 13px !important
  background transparent !important

.sidebar-heading span
  font-size 1.2em
  font-weight bold
  color $accentColor

.sidebar-heading.open span
  font-weight bold

.sidebar a.sidebar-link.active
  color #0f172a !important
  font-size 14px !important
  background rgba(13, 148, 136, 0.12) !important

.dark .sidebar a.sidebar-link.active
  color rgba(248, 250, 252, 0.95) !important
  background rgba(13, 148, 136, 0.22) !important

.sidebar-sub-headers a.sidebar-link
  margin 0 1rem 0 1rem !important

.sidebar-group.is-sub-group > .sidebar-heading:not(.clickable)
  opacity 0.5

// 文档阅读：左侧整列与目录列表不铺白/灰底，随页面背景透出
.sidebar
  background transparent !important
  backdrop-filter blur(12px) saturate(150%)
  border-right 1px solid rgba(15, 23, 42, 0.08) !important

.sidebar ul.sidebar-links
  background transparent !important

// SidebarGroup.vue 默认给分组铺 var(--background-color)，会整块发白
.sidebar .sidebar-group
  background transparent !important

.dark .sidebar
  background transparent !important
  border-right-color rgba(255, 255, 255, 0.08) !important

.dark .sidebar ul.sidebar-links
  background transparent !important

.dark .sidebar .sidebar-group
  background transparent !important

// 右侧大纲：弱化容器，条目样式在 SubSidebar.vue（sub-sidebar-link）
.theme-container .sub-sidebar
  padding 0.35rem 0.25rem
  background rgba(248, 250, 252, 0.35)
  backdrop-filter blur(10px) saturate(140%)
  border-radius 12px
  border 1px solid rgba(15, 23, 42, 0.08)
  box-shadow none

.dark .theme-container .sub-sidebar
  background rgba(15, 23, 42, 0.35)
  border-color rgba(255, 255, 255, 0.08)
  box-shadow none

// 桌面端：顶栏「目录 / 大纲」按钮控制左右侧栏显隐（与移动端抽屉侧栏无关）
@media (min-width: 720px)
  .theme-container .sidebar
    transition transform 0.22s ease, opacity 0.22s ease
  .theme-container .sub-sidebar
    transition transform 0.22s ease, opacity 0.22s ease

  .theme-container.hide-left-doc-nav
    .page, .password-wrapper-in
      margin-left 0 !important
    .sidebar
      transform translateX(-100%)
      opacity 0
      pointer-events none

  .theme-container.hide-right-doc-outline
    .page
      padding-right 0 !important
    .sub-sidebar
      opacity 0
      pointer-events none
      transform translateX(calc(100% + 2rem))
